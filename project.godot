;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Dance Notation"
run/main_scene="uid://cn4k3vr0klbir"
config/quit_on_go_back=false
